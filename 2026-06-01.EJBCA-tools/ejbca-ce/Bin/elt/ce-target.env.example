# ce-target.env — CE-side target config for ELT / curl / cert-grep (TEMPLATE).
#
# The live file is generated per install by:
#   ./Bin/220.certs/221.collect-certs.sh
# which writes it to $localDir/ce-target.env (default ./local).
#
# To set it up by hand instead, copy this file to $localDir/ce-target.env and
# edit the cert paths to point at wherever you collected the certs.

export ELT_HOST=host.k3d.internal
export ELT_PORT=8443
export ELT_CERT=/path/to/certs/ELT-Admin.crt
export ELT_KEY=/path/to/certs/ELT-Admin.key
export ELT_CA_CERT=/path/to/certs/ManagementCA.crt
